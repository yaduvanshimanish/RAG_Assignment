# Required: Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model identifiers
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# FAISS vector dimension must match the embedding model output
# gemini-embedding-001 produces 3072-dimensional vectors
FAISS_DIMENSION=3072
FAISS_INDEX_PATH=./data/faiss_index

# Document processing limits
MAX_DOCUMENTS=20
MAX_PAGES_PER_DOC=1000
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_RETRIEVED_CHUNKS=5
MAX_FILE_SIZE_MB=100

# SQLite database path (relative)
DATABASE_URL=sqlite:///./data/rag_metadata.db

# File upload directory
UPLOAD_DIR=./data/uploads

# Set to true only during development
DEBUG=false

# For Railway deployment:
# Set these in Railway dashboard under Variables tab.
# GEMINI_API_KEY is required.
# DATABASE_URL defaults to SQLite inside the container.
# For production, use Railway's PostgreSQL plugin and set DATABASE_URL to the
# provided PostgreSQL connection string (starts with postgresql://).
